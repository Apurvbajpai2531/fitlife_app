<!DOCTYPE html>
<html>
  <head>
    <title>FitLife App</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_include_tag "application", "data-turbo-track": "reload", defer: true %>
  </head>

  <body class="bg-gray-100 text-gray-900 font-sans">
    <header class="bg-white shadow sticky top-0 z-50">
      <div class="max-w-7xl mx-auto px-4 py-4 flex justify-between items-center">
        <h1 class="text-2xl font-bold text-indigo-600">🏋️‍♂️ FitLife</h1>

        <% if user_signed_in? %>
          <nav class="space-x-4">
            <%= link_to "Dashboard", root_path, class: "text-gray-700 hover:text-indigo-500" %>
            <%= link_to "Workouts", workouts_path, class: "text-gray-700 hover:text-indigo-500" %>
            <%= link_to "Plans", plans_path, class: "text-gray-700 hover:text-indigo-500" %>
            <%= link_to "Logout", destroy_user_session_path, method: :delete, class: "text-red-500 hover:underline" %>
          </nav>
        <% else %>
          <%= link_to "Login", new_user_session_path, class: "text-indigo-500 hover:underline" %>
        <% end %>
      </div>
    </header>

    <main class="max-w-7xl mx-auto p-6">
      <% if notice %>
        <div class="bg-green-100 border border-green-400 text-green-700 px-4 py-3 rounded mb-4">
          <%= notice %>
        </div>
      <% end %>

      <% if alert %>
        <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded mb-4">
          <%= alert %>
        </div>
      <% end %>

      <%= yield %>
    </main>

    <footer class="bg-white text-center p-4 shadow mt-12">
      <p class="text-sm text-gray-500">© <%= Date.today.year %> FitLife. Stay fit, stay strong! 💪</p>
    </footer>
  </body>
</html>
