<h1 class="text-3xl font-bold text-indigo-700 mb-6">My Workouts</h1>

<div class="mb-6">
  <%= search_form_for @q, url: workouts_path, method: :get do |f| %>
    <div class="flex space-x-2">
      <%= f.text_field :title_cont, placeholder: "Search workouts...", class: "w-full p-2 border border-gray-300 rounded-xl" %>
      <%= f.submit "Search", class: "bg-indigo-600 text-white px-4 py-2 rounded-xl hover:bg-indigo-700" %>
    </div>
  <% end %>
</div>

<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
  <% @workouts.each do |workout| %>
    <div class="bg-white p-6 shadow-lg rounded-2xl hover:shadow-2xl transition">
      <h2 class="text-xl font-bold text-indigo-700"><%= workout.title %></h2>
      <p class="text-gray-600 mt-2"><%= truncate(workout.description, length: 100) %></p>
      <p class="mt-4 text-sm text-gray-400">Created: <%= workout.created_at.strftime("%b %d, %Y") %></p>
      <%= link_to "View", workout_path(workout), class: "inline-block mt-4 text-indigo-500 hover:underline" %>
    </div>
  <% end %>
</div>
